rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: campaigns
    // Document ID: Auto-generated
    // Fields:
    //   - userId: string (required) - The UID of the creator
    //   - originalContent: string (required) - The original text
    //   - topic: string (optional) - The topic
    //   - repurposedData: string (required) - JSON stringified data
    //   - createdAt: timestamp (required) - Creation time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }

    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }

    // Domain Validators
    function isValidCampaign(data) {
      return hasRequiredFields(['userId', 'originalContent', 'repurposedData', 'createdAt']) &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.originalContent is string && data.originalContent.size() < 100000 &&
             data.repurposedData is string && data.repurposedData.size() < 500000 &&
             data.createdAt is timestamp &&
             (!('topic' in data) || (data.topic is string && data.topic.size() < 500));
    }

    match /campaigns/{campaignId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isValidCampaign(request.resource.data) && uidUnchanged();
      allow update: if isOwner(resource.data.userId) && isValidCampaign(request.resource.data) && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOwner(resource.data.userId);
    }
  }
}
