{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "description": "The user's profile picture URL."
        },
        "lastLogin": {
          "type": "string",
          "format": "date-time",
          "description": "The last time the user logged in."
        }
      },
      "required": ["uid", "email", "lastLogin"]
    },
    "Campaign": {
      "title": "Campaign",
      "description": "A repurposed content campaign.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who created the campaign."
        },
        "originalContent": {
          "type": "string",
          "description": "The original content provided by the user."
        },
        "topic": {
          "type": "string",
          "description": "The main topic of the campaign."
        },
        "repurposedData": {
          "type": "string",
          "description": "JSON stringified repurposed data."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the campaign was created."
        }
      },
      "required": ["userId", "originalContent", "repurposedData", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    },
    "campaigns/{campaignId}": {
      "schema": {
        "$ref": "#/entities/Campaign"
      },
      "description": "Stores user campaigns."
    }
  }
}
